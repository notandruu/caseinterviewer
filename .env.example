# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# OpenAI Configuration
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_JSON_MODEL=gpt-4o-2024-08-06

# ElevenLabs (Optional - TTS)
# Voice ID is NOT secret and can be public
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=jRAAK67SEFE9m7ci5DhD
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# Echo SDK (Optional)
NEXT_PUBLIC_ECHO_APP_ID=your_echo_app_id_here
ECHO_SECRET_KEY=your_echo_secret_key_here

# Feature Flags
NEXT_PUBLIC_VOICE_SESSION_V2_ENABLED=false
