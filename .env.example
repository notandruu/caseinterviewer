# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenAI Configuration (Required for LLM chat)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs (Optional - for premium TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Echo SDK (for future integration)
# NEXT_PUBLIC_ECHO_PUBLIC_KEY=pk_...
# ECHO_SECRET_KEY=sk_...

# Feature Flags
# Voice Session V2 - Redesigned interview experience (default: false)
NEXT_PUBLIC_VOICE_SESSION_V2_ENABLED=false
