# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# OpenAI
OPENAI_API_KEY=sk-...

# ElevenLabs (optional - falls back to browser TTS)
ELEVENLABS_API_KEY=your_elevenlabs_key

# ETH Payments (Base L2)
# Contract deployed via: cd contracts && forge script script/Deploy.s.sol --rpc-url base_sepolia --broadcast
NEXT_PUBLIC_PAYMENT_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_SESSION_PRICE_ETH=0.001
NEXT_PUBLIC_SCORE_THRESHOLD=70
# 84532 = Base Sepolia (testnet), 8453 = Base Mainnet
NEXT_PUBLIC_CHAIN_ID=84532

# WalletConnect (optional - enables WalletConnect connector)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Server-side admin wallet that calls completeSession() on-chain
PAYMENT_ADMIN_PRIVATE_KEY=0x...
PAYMENT_ADMIN_ADDRESS=0x...

# Foundry deploy (contracts directory only)
DEPLOYER_PRIVATE_KEY=0x...
BASESCAN_API_KEY=your_basescan_api_key
